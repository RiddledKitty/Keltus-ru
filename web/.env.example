# Astro build-time fetcher reads from Directus on admin.keltus.ru.
# In dev, point at the local Directus instance.

DIRECTUS_URL="http://localhost:8055"

# Public read token, generated after first Directus boot.
# (Public role's READ permissions are enough; the token avoids rate limits.)
DIRECTUS_TOKEN=""

# Where the client-side contact form POSTs. Anything prefixed PUBLIC_ is
# inlined into the browser bundle by Astro. In dev, point at the local
# Directus (the contact-form endpoint mounts at /contact-form/submit).
PUBLIC_CMS_URL="http://localhost:8055"
