---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  technologies, CATEGORY_LABEL, CATEGORY_BLURB, CATEGORY_ORDER,
  type Technology, type Category,
} from '../data/technologies';

const grouped = new Map<Category, Technology[]>();
for (const t of technologies) {
  const list = grouped.get(t.category) ?? [];
  list.push(t);
  grouped.set(t.category, list);
}
const sections = CATEGORY_ORDER
  .map(cat => ({ cat, items: grouped.get(cat) ?? [] }))
  .filter(s => s.items.length > 0);
---

<BaseLayout seo={{
  title: 'Технологии — Keltus',
  description: 'Языки, фреймворки, протоколы шифрования и платформы, на которых работают проекты Keltus. Нажмите на иконку книги в любой строке, чтобы прочитать описание простыми словами.',
}}>
  <section class="kel-page-head">
    <div class="kel-container">
      <span class="kel-eyebrow">Возможности</span>
      <h1>Что мы используем и зачем.</h1>
      <p>Это реальный стек по всем нашим проектам — не список пожеланий. Каждый пункт работает в продакшене
         как минимум одного проекта Keltus. Нажмите на иконку книги в любой строке, чтобы прочитать
         простыми словами, что это и почему важно.</p>
    </div>
  </section>

  <section class="kel-section kel-container">
    {sections.map(({ cat, items }) => (
      <div class="kel-techcat">
        <header class="kel-techcat__head">
          <h2><span class="kel-eyebrow">{CATEGORY_LABEL[cat]}</span></h2>
          <p>{CATEGORY_BLURB[cat]}</p>
        </header>
        <table class="kel-techtable">
          <colgroup>
            <col class="kel-techtable__col-name" />
            <col class="kel-techtable__col-use" />
            <col class="kel-techtable__col-on" />
            <col class="kel-techtable__col-info" />
          </colgroup>
          <thead>
            <tr>
              <th>Технология</th>
              <th>Для чего используем</th>
              <th>В проектах</th>
              <th><span class="kel-sr-only">Подробнее</span></th>
            </tr>
          </thead>
          <tbody>
            {items.map(t => (
              <tr>
                <td class="kel-techtable__name">{t.name}</td>
                <td class="kel-techtable__use">{t.use}</td>
                <td class="kel-techtable__on">
                  {t.on.length > 0
                    ? <ul>{t.on.map(p => <li>{p}</li>)}</ul>
                    : <span class="kel-techtable__none">—</span>}
                </td>
                <td class="kel-techtable__info">
                  <button
                    type="button"
                    class="kel-techinfo-btn"
                    data-tech-name={t.name}
                    data-tech-use={t.use}
                    data-tech-deep={t.deep}
                    data-tech-on={t.on.join(',')}
                    aria-label={`Подробнее о ${t.name}`}
                  >
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path
                        d="M3 4.5A1.5 1.5 0 0 1 4.5 3H11v15.5H4.5A1.5 1.5 0 0 1 3 17V4.5Zm10 -1.5h6.5A1.5 1.5 0 0 1 21 4.5V17a1.5 1.5 0 0 1 -1.5 1.5H13V3Z"
                        fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"
                      />
                      <path d="M12 3v15.5" fill="none" stroke="currentColor" stroke-width="1.6" />
                      <path d="M6 8h3M6 11h3M15 8h3M15 11h3" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    </svg>
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ))}
  </section>

  <!-- Modal — populated and opened by the click script below. -->
  <dialog class="kel-techmodal" id="kel-techmodal" aria-labelledby="kel-techmodal-title">
    <button type="button" class="kel-techmodal__close" data-techmodal-close aria-label="Закрыть">
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
        <path d="M5 5l14 14M19 5L5 19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
    <span class="kel-eyebrow" id="kel-techmodal-eyebrow">Технология</span>
    <h3 id="kel-techmodal-title"></h3>
    <p class="kel-techmodal__use" id="kel-techmodal-use"></p>
    <div class="kel-techmodal__deep" id="kel-techmodal-deep"></div>
    <div class="kel-techmodal__on" id="kel-techmodal-on" hidden>
      <span class="kel-techmodal__on-label">В продакшене на</span>
      <ul id="kel-techmodal-on-list"></ul>
    </div>
  </dialog>
</BaseLayout>

<style>
  .kel-sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .kel-page-head {
    padding: clamp(72px, 10vw, 120px) 0 clamp(40px, 6vw, 64px);
    border-bottom: 1px solid var(--kel-border);
    background:
      radial-gradient(50% 60% at 0% 0%, rgba(56,189,248,0.08), transparent 70%),
      var(--kel-bg);
  }
  .kel-page-head h1 {
    font-size: clamp(36px, 6vw, 64px);
    margin: 10px 0 16px;
    letter-spacing: -0.03em;
  }
  .kel-page-head p {
    color: var(--kel-text-2);
    max-width: 64ch;
    font-size: 17px;
    margin: 0;
  }

  .kel-section { padding: 64px 0 96px; }

  .kel-techcat { margin-bottom: 72px; }
  .kel-techcat:last-child { margin-bottom: 0; }
  .kel-techcat__head { margin-bottom: 18px; }
  .kel-techcat__head h2 { margin: 0 0 8px; font-size: 22px; }
  .kel-techcat__head p {
    margin: 0;
    color: var(--kel-text-2);
    font-size: 15.5px;
    max-width: 70ch;
  }

  /* Table */
  .kel-techtable {
    width: 100%;
    border-collapse: collapse;
    background: var(--kel-bg-alt);
    border: 1px solid var(--kel-border);
    border-radius: var(--kel-radius-lg);
    overflow: hidden;
    font-size: 14.5px;
  }
  .kel-techtable thead { background: var(--kel-bg-3); }
  .kel-techtable th {
    text-align: left;
    padding: 14px 18px;
    font-family: var(--kel-font-mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kel-text-3);
    font-weight: 700;
    border-bottom: 1px solid var(--kel-border);
  }
  .kel-techtable td {
    padding: 14px 18px;
    vertical-align: top;
    color: var(--kel-text-2);
    line-height: 1.55;
  }

  /* Zebra striping — alternating rows for readability */
  .kel-techtable tbody tr:nth-child(odd)  { background: var(--kel-bg-alt); }
  .kel-techtable tbody tr:nth-child(even) { background: var(--kel-bg-3); }
  .kel-techtable tbody tr { transition: background .15s ease; }
  .kel-techtable tbody tr:hover { background: rgba(56, 189, 248, 0.07); }

  .kel-techtable__name {
    color: var(--kel-text);
    font-weight: 600;
    white-space: nowrap;
    font-size: 14.5px;
  }
  .kel-techtable__use { color: var(--kel-text-2); }
  .kel-techtable__none {
    color: var(--kel-text-3);
    font-family: var(--kel-font-mono);
    font-size: 11px;
  }

  .kel-techtable__col-name { width: 20%; }
  .kel-techtable__col-use  { width: auto; }
  .kel-techtable__col-on   { width: 22%; }
  .kel-techtable__col-info { width: 56px; }

  .kel-techtable__on ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .kel-techtable__on li {
    font-family: var(--kel-font-mono);
    font-size: 11px;
    color: var(--kel-accent);
    background: var(--kel-accent-soft);
    padding: 3px 7px;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .kel-techtable__info { text-align: center; }
  .kel-techinfo-btn {
    background: transparent;
    border: 1px solid var(--kel-border);
    color: var(--kel-text-2);
    width: 32px;
    height: 32px;
    border-radius: 6px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: color .15s ease, border-color .15s ease, background .15s ease, transform .15s ease;
  }
  .kel-techinfo-btn:hover,
  .kel-techinfo-btn:focus-visible {
    color: var(--kel-accent);
    border-color: var(--kel-accent);
    background: var(--kel-accent-soft);
    transform: translateY(-1px);
    outline: none;
  }

  /* --- Modal ----------------------------------------------------------- */
  .kel-techmodal {
    border: 1px solid var(--kel-border);
    background: var(--kel-bg-alt);
    color: var(--kel-text);
    border-radius: var(--kel-radius-lg);
    padding: clamp(28px, 4vw, 40px);
    max-width: 640px;
    width: calc(100% - 48px);
    margin: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55);
    position: relative;
  }
  .kel-techmodal::backdrop {
    background: rgba(4, 17, 28, 0.7);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .kel-techmodal[open] {
    animation: kel-tech-modal-in .18s ease-out;
  }
  @keyframes kel-tech-modal-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .kel-techmodal h3 {
    font-size: clamp(22px, 3vw, 28px);
    margin: 8px 0 12px;
    letter-spacing: -0.02em;
  }
  .kel-techmodal__use {
    margin: 0 0 18px;
    color: var(--kel-text);
    font-size: 15px;
    font-weight: 500;
    padding: 12px 14px;
    background: var(--kel-bg-3);
    border-left: 3px solid var(--kel-accent);
    border-radius: 4px;
  }
  .kel-techmodal__deep {
    color: var(--kel-text-2);
    font-size: 15.5px;
    line-height: 1.7;
  }
  .kel-techmodal__deep p { margin: 0; }

  .kel-techmodal__on {
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid var(--kel-border);
  }
  .kel-techmodal__on-label {
    font-family: var(--kel-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kel-text-3);
    display: block;
    margin-bottom: 8px;
  }
  .kel-techmodal__on ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .kel-techmodal__on li {
    font-family: var(--kel-font-mono);
    font-size: 11.5px;
    color: var(--kel-accent);
    background: var(--kel-accent-soft);
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .kel-techmodal__close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--kel-border);
    color: var(--kel-text-2);
    border-radius: 6px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: color .15s ease, border-color .15s ease;
  }
  .kel-techmodal__close:hover,
  .kel-techmodal__close:focus-visible {
    color: var(--kel-text);
    border-color: var(--kel-accent);
    outline: none;
  }

  /* Mobile: collapse table to card-per-row */
  @media (max-width: 720px) {
    .kel-techtable, .kel-techtable thead, .kel-techtable tbody,
    .kel-techtable th, .kel-techtable td, .kel-techtable tr,
    .kel-techtable colgroup, .kel-techtable col {
      display: block;
    }
    .kel-techtable thead { display: none; }
    .kel-techtable tbody tr {
      padding: 16px 18px;
      position: relative;
    }
    .kel-techtable td { padding: 4px 0; border-bottom: 0; }
    .kel-techtable__name { font-size: 16px; margin-bottom: 2px; padding-right: 48px; }
    .kel-techtable__use  { font-size: 14px; }
    .kel-techtable__info {
      position: absolute;
      top: 14px;
      right: 16px;
      padding: 0;
    }
  }
</style>

<script>
  function setupTechModal() {
    const modal = document.getElementById('kel-techmodal') as HTMLDialogElement | null;
    if (!modal || (modal as any)._wired) return;
    (modal as any)._wired = true;

    const titleEl = document.getElementById('kel-techmodal-title');
    const useEl   = document.getElementById('kel-techmodal-use');
    const deepEl  = document.getElementById('kel-techmodal-deep');
    const onWrap  = document.getElementById('kel-techmodal-on');
    const onList  = document.getElementById('kel-techmodal-on-list');

    function openFor(btn: HTMLButtonElement) {
      const name = btn.dataset.techName || '';
      const use  = btn.dataset.techUse  || '';
      const deep = btn.dataset.techDeep || '';
      const onCsv = btn.dataset.techOn  || '';
      const onArr = onCsv.split(',').map(s => s.trim()).filter(Boolean);

      if (titleEl) titleEl.textContent = name;
      if (useEl)   useEl.textContent   = use;
      if (deepEl)  deepEl.innerHTML    = '<p>' + escapeHtml(deep) + '</p>';

      if (onWrap && onList) {
        if (onArr.length > 0) {
          onList.innerHTML = onArr.map(p => `<li>${escapeHtml(p)}</li>`).join('');
          onWrap.hidden = false;
        } else {
          onList.innerHTML = '';
          onWrap.hidden = true;
        }
      }
      try { modal!.showModal(); } catch { /* already open */ }
    }

    function escapeHtml(s: string) {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    // Open on any reading-icon click. Delegated so it survives view-transitions.
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLButtonElement>('.kel-techinfo-btn');
      if (btn) {
        e.preventDefault();
        openFor(btn);
        return;
      }
      // Close on backdrop click (when the dialog itself is the click target)
      if (target === modal) {
        modal.close();
      }
    });

    // Close button
    modal.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('[data-techmodal-close]')) {
        modal.close();
      }
    });
  }
  setupTechModal();
  document.addEventListener('astro:page-load', setupTechModal);
</script>
