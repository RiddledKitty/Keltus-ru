---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Контакты — Keltus',
  description: 'Расскажите о своём проекте. Новые сборки, запросы на оценку, партнёрства — каждое сообщение попадает напрямую к инженеру.',
};

// Where the Astro client posts the form. Override with PUBLIC_CMS_URL at
// build time when developing against a local Directus instance.
const CMS_URL = import.meta.env.PUBLIC_CMS_URL || 'https://admin.keltus.ru';

/* Country dialing codes for the phone-number picker. US + CA are
 * pinned at the top (US is the default; CA shares the +1 dial), then
 * the rest run alphabetical by ISO 3166-1 alpha-2 code. Each option
 * shows just the flag, dial code, and 2-letter abbreviation so the
 * select stays narrow and doesn't crowd the phone-number input.
 *
 * `name` is kept for the option's tooltip / accessible label only —
 * not rendered in the closed select. */
// Russian-market default first (this is keltus.ru). LV/BY/KZ/UA follow as
// the most likely additional markets, then the rest alphabetical by code.
const TOP_COUNTRIES = [
  { code: 'RU', dial: '7',   name: 'Россия',           flag: '🇷🇺' },
  { code: 'LV', dial: '371', name: 'Латвия',           flag: '🇱🇻' },
  { code: 'BY', dial: '375', name: 'Беларусь',         flag: '🇧🇾' },
  { code: 'KZ', dial: '7',   name: 'Казахстан',        flag: '🇰🇿' },
  { code: 'UA', dial: '380', name: 'Украина',          flag: '🇺🇦' },
];
const REST_COUNTRIES = [
  { code: 'AE', dial: '971', name: 'ОАЭ',                  flag: '🇦🇪' },
  { code: 'AR', dial: '54',  name: 'Аргентина',            flag: '🇦🇷' },
  { code: 'AT', dial: '43',  name: 'Австрия',              flag: '🇦🇹' },
  { code: 'AU', dial: '61',  name: 'Австралия',            flag: '🇦🇺' },
  { code: 'BE', dial: '32',  name: 'Бельгия',              flag: '🇧🇪' },
  { code: 'BR', dial: '55',  name: 'Бразилия',             flag: '🇧🇷' },
  { code: 'CA', dial: '1',   name: 'Канада',               flag: '🇨🇦' },
  { code: 'CH', dial: '41',  name: 'Швейцария',            flag: '🇨🇭' },
  { code: 'CL', dial: '56',  name: 'Чили',                 flag: '🇨🇱' },
  { code: 'CN', dial: '86',  name: 'Китай',                flag: '🇨🇳' },
  { code: 'CO', dial: '57',  name: 'Колумбия',             flag: '🇨🇴' },
  { code: 'CZ', dial: '420', name: 'Чехия',                flag: '🇨🇿' },
  { code: 'DE', dial: '49',  name: 'Германия',             flag: '🇩🇪' },
  { code: 'DK', dial: '45',  name: 'Дания',                flag: '🇩🇰' },
  { code: 'EE', dial: '372', name: 'Эстония',              flag: '🇪🇪' },
  { code: 'EG', dial: '20',  name: 'Египет',               flag: '🇪🇬' },
  { code: 'ES', dial: '34',  name: 'Испания',              flag: '🇪🇸' },
  { code: 'FI', dial: '358', name: 'Финляндия',            flag: '🇫🇮' },
  { code: 'FR', dial: '33',  name: 'Франция',              flag: '🇫🇷' },
  { code: 'GR', dial: '30',  name: 'Греция',               flag: '🇬🇷' },
  { code: 'HK', dial: '852', name: 'Гонконг',              flag: '🇭🇰' },
  { code: 'HU', dial: '36',  name: 'Венгрия',              flag: '🇭🇺' },
  { code: 'ID', dial: '62',  name: 'Индонезия',            flag: '🇮🇩' },
  { code: 'IE', dial: '353', name: 'Ирландия',             flag: '🇮🇪' },
  { code: 'IL', dial: '972', name: 'Израиль',              flag: '🇮🇱' },
  { code: 'IN', dial: '91',  name: 'Индия',                flag: '🇮🇳' },
  { code: 'IT', dial: '39',  name: 'Италия',               flag: '🇮🇹' },
  { code: 'JP', dial: '81',  name: 'Япония',               flag: '🇯🇵' },
  { code: 'KE', dial: '254', name: 'Кения',                flag: '🇰🇪' },
  { code: 'KR', dial: '82',  name: 'Южная Корея',          flag: '🇰🇷' },
  { code: 'LT', dial: '370', name: 'Литва',                flag: '🇱🇹' },
  { code: 'MX', dial: '52',  name: 'Мексика',              flag: '🇲🇽' },
  { code: 'MY', dial: '60',  name: 'Малайзия',             flag: '🇲🇾' },
  { code: 'NG', dial: '234', name: 'Нигерия',              flag: '🇳🇬' },
  { code: 'NL', dial: '31',  name: 'Нидерланды',           flag: '🇳🇱' },
  { code: 'NO', dial: '47',  name: 'Норвегия',             flag: '🇳🇴' },
  { code: 'NZ', dial: '64',  name: 'Новая Зеландия',       flag: '🇳🇿' },
  { code: 'PE', dial: '51',  name: 'Перу',                 flag: '🇵🇪' },
  { code: 'PH', dial: '63',  name: 'Филиппины',            flag: '🇵🇭' },
  { code: 'PK', dial: '92',  name: 'Пакистан',             flag: '🇵🇰' },
  { code: 'PL', dial: '48',  name: 'Польша',               flag: '🇵🇱' },
  { code: 'PT', dial: '351', name: 'Португалия',           flag: '🇵🇹' },
  { code: 'RO', dial: '40',  name: 'Румыния',              flag: '🇷🇴' },
  { code: 'SA', dial: '966', name: 'Саудовская Аравия',    flag: '🇸🇦' },
  { code: 'SE', dial: '46',  name: 'Швеция',               flag: '🇸🇪' },
  { code: 'SG', dial: '65',  name: 'Сингапур',             flag: '🇸🇬' },
  { code: 'TH', dial: '66',  name: 'Таиланд',              flag: '🇹🇭' },
  { code: 'TR', dial: '90',  name: 'Турция',               flag: '🇹🇷' },
  { code: 'TW', dial: '886', name: 'Тайвань',              flag: '🇹🇼' },
  { code: 'UK', dial: '44',  name: 'Великобритания',       flag: '🇬🇧' },
  { code: 'US', dial: '1',   name: 'США',                  flag: '🇺🇸' },
  { code: 'VE', dial: '58',  name: 'Венесуэла',            flag: '🇻🇪' },
  { code: 'VN', dial: '84',  name: 'Вьетнам',              flag: '🇻🇳' },
  { code: 'ZA', dial: '27',  name: 'ЮАР',                  flag: '🇿🇦' },
];
const COUNTRY_CODES = [...TOP_COUNTRIES, ...REST_COUNTRIES];
---

<BaseLayout seo={seo}>
  <main class="kel-contact">
    <header class="kel-contact__head">
      <div class="kel-contact__head-inner">
        <div class="kel-contact__kicker">Контакты</div>
        <h1 class="kel-contact__title">Расскажите о проекте.</h1>
        <p class="kel-contact__lede">
          Новые сборки, запросы на оценку, партнёрства или просто сложная
          задача в поисках подходящего инструмента — напишите. Каждое сообщение
          попадает в почту настоящего инженера, а не в маркетинговый ящик.
        </p>
      </div>
    </header>

    <section class="kel-contact__body">
      <div class="kel-contact__grid">
        <aside class="kel-contact__aside">
          <div class="kel-contact__card">
            <h3>С чем к нам обращаются</h3>
            <ul>
              <li>Веб-платформа под заказ с нуля</li>
              <li>Ускорение существующего сайта</li>
              <li>Постквантовое шифрование переписки или авторизации</li>
              <li>Интеграция ИИ — контент, поиск, рекомендации</li>
              <li>Автоматизация и бэкенд на Go</li>
              <li>Интеграция с железом (ЧПУ, IoT, встраиваемые системы)</li>
            </ul>
          </div>
          <div class="kel-contact__card">
            <h3>Что будет дальше</h3>
            <p>
              Мы сами читаем каждое сообщение — обычно в течение одного-двух
              дней. Если задача нам подходит, согласуем короткий созвон,
              обсудим объём работ и пришлём письменную оценку. Без шаблонов,
              без «агентского пакета» — только подходящий инструмент под задачу.
            </p>
          </div>
        </aside>

        <form class="kel-contact__form" id="kel-contact-form" data-cms-url={CMS_URL} novalidate>
          <div class="kel-contact__row">
            <div class="kel-contact__field">
              <label for="cf-name">Имя <span aria-hidden="true">*</span></label>
              <input id="cf-name" name="name" type="text" required autocomplete="name" maxlength="120" />
            </div>
            <div class="kel-contact__field">
              <label for="cf-email">E-mail <span aria-hidden="true">*</span></label>
              <input id="cf-email" name="email" type="email" required autocomplete="email" maxlength="200" />
            </div>
          </div>

          <div class="kel-contact__row">
            <div class="kel-contact__field">
              <label for="cf-phone-num">Телефон <span class="kel-contact__opt">(необязательно)</span></label>
              <div class="kel-contact__phone">
                <select id="cf-phone-cc" name="phone_cc" aria-label="Код страны">
                  {TOP_COUNTRIES.map(c => (
                    <option value={`${c.code}|${c.dial}`} selected={c.code === 'RU'} title={c.name}>
                      {c.flag} +{c.dial} {c.code}
                    </option>
                  ))}
                  <option disabled>──────────</option>
                  {REST_COUNTRIES.map(c => (
                    <option value={`${c.code}|${c.dial}`} title={c.name}>
                      {c.flag} +{c.dial} {c.code}
                    </option>
                  ))}
                </select>
                <input
                  id="cf-phone-num"
                  name="phone_num"
                  type="tel"
                  autocomplete="tel-national"
                  inputmode="tel"
                  maxlength="20"
                  placeholder="912 345 6789"
                />
              </div>
            </div>
            <div class="kel-contact__field">
              <label for="cf-topic">Тема</label>
              <select id="cf-topic" name="topic">
                <option value="general">Общий вопрос</option>
                <option value="new-build">Новый проект / запрос на сборку</option>
                <option value="quote">Запрос оценки</option>
                <option value="partnership">Партнёрство / сотрудничество</option>
                <option value="press">Пресса / СМИ</option>
                <option value="technical">Сайт / технический вопрос</option>
              </select>
            </div>
          </div>

          <div class="kel-contact__field">
            <label for="cf-subject">Тема письма <span aria-hidden="true">*</span></label>
            <input id="cf-subject" name="subject" type="text" required maxlength="200" />
          </div>

          <div class="kel-contact__field">
            <label for="cf-message">Сообщение <span aria-hidden="true">*</span></label>
            <textarea id="cf-message" name="message" required rows="8" maxlength="6000" placeholder="Что вы хотите построить, починить или заменить? Укажите ссылки, сроки и ограничения — это поможет оценить объём."></textarea>
          </div>

          {/* Honeypot — bots fill this; humans don't see it */}
          <div class="kel-contact__hp" aria-hidden="true">
            <label>Оставьте это поле пустым</label>
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="kel-contact__actions">
            <button type="submit" class="kel-contact__submit">
              <span class="kel-contact__submit-label">Отправить</span>
              <span class="kel-contact__submit-spinner" aria-hidden="true"></span>
            </button>
            <p class="kel-contact__note">
              Сообщение уходит прямо в почту инженера. Обычно отвечаем за один-два дня.
            </p>
          </div>

          <div class="kel-contact__status" role="status" aria-live="polite"></div>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  function setupContactForm() {
    const form = document.getElementById('kel-contact-form') as HTMLFormElement | null;
    if (!form || (form as any)._wired) return;
    (form as any)._wired = true;
    const cmsUrl = form.dataset.cmsUrl || '';

    const status = form.querySelector<HTMLDivElement>('.kel-contact__status');
    const submit = form.querySelector<HTMLButtonElement>('.kel-contact__submit');

    function setStatus(kind: 'idle' | 'ok' | 'error' | 'sending', msg: string) {
      if (!status) return;
      status.className = 'kel-contact__status is-' + kind;
      status.textContent = msg;
    }

    // Strip non-digits live so the input stays clean as the user types.
    // (Visual + the value submitted to the server both end up digits-only.)
    const phoneNumEl = form.querySelector<HTMLInputElement>('#cf-phone-num');
    phoneNumEl?.addEventListener('input', () => {
      const before = phoneNumEl.value;
      const after = before.replace(/\D+/g, '');
      if (before !== after) {
        const caret = (phoneNumEl.selectionStart ?? after.length) - (before.length - after.length);
        phoneNumEl.value = after;
        try { phoneNumEl.setSelectionRange(Math.max(0, caret), Math.max(0, caret)); } catch {}
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const data = Object.fromEntries(new FormData(form).entries());
      // Honeypot — silently succeed without sending
      if (typeof data.website === 'string' && data.website.trim() !== '') {
        setStatus('ok', "Спасибо — сообщение отправлено.");
        form.reset();
        return;
      }

      const ccRaw = String(data.phone_cc || 'RU|7');
      const dial  = (ccRaw.split('|')[1] || '7').replace(/\D+/g, '');
      const digits = String(data.phone_num || '').replace(/\D+/g, '');
      const phone = digits ? `+${dial}${digits}` : '';

      submit?.classList.add('is-loading');
      submit?.setAttribute('disabled', 'true');
      setStatus('idle', '');

      const overlay = openTerminalOverlay(form, setStatus, submit);

      try {
        const res = await fetch(`${cmsUrl}/contact-form/submit-stream`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'text/event-stream',
          },
          body: JSON.stringify({
            name: data.name,
            email: data.email,
            phone,
            subject: data.subject,
            topic: data.topic || 'general',
            message: data.message,
          }),
        });
        if (!res.body) throw new Error('Браузер не поддерживает потоковую передачу.');

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          let i;
          while ((i = buf.indexOf('\n\n')) >= 0) {
            const chunk = buf.slice(0, i);
            buf = buf.slice(i + 2);
            const dataLines = chunk
              .split('\n')
              .filter(l => l.startsWith('data:'))
              .map(l => l.slice(5).replace(/^ /, ''));
            if (!dataLines.length) continue;
            try { overlay.handle(JSON.parse(dataLines.join('\n'))); } catch {}
          }
        }
        overlay.finalizeIfNeeded();
      } catch (err: any) {
        overlay.handle({ type: 'log', level: 'err', text: `Сетевая ошибка: ${err?.message || err}` });
        overlay.handle({ type: 'done', ok: false, error: 'Сетевая ошибка — попробуйте ещё раз.' });
      }
      // submit button is re-enabled by the overlay when the playback queue drains
    });
  }

  type LogEvent = { type: 'log'; level: 'info' | 'ok' | 'warn' | 'err' | 'wire'; text: string };
  type DoneEvent = { type: 'done'; ok: boolean; id?: number; error?: string };

  function openTerminalOverlay(
    form: HTMLFormElement,
    setStatus: (k: any, m: string) => void,
    submit: HTMLButtonElement | null,
  ) {
    const overlay = document.createElement('div');
    overlay.className = 'kel-smtp-overlay';
    overlay.innerHTML = `
      <div class="kel-smtp-terminal" role="log" aria-label="Статус отправки" aria-live="polite">
        <div class="kel-smtp-header">
          <span class="kel-smtp-dot kel-smtp-dot--r"></span>
          <span class="kel-smtp-dot kel-smtp-dot--y"></span>
          <span class="kel-smtp-dot kel-smtp-dot--g"></span>
          <span class="kel-smtp-title">contact-form: отправка…</span>
          <button class="kel-smtp-close" type="button" aria-label="Закрыть" hidden>&times;</button>
        </div>
        <div class="kel-smtp-body"></div>
        <div class="kel-smtp-footer">
          <span class="kel-smtp-spinner" aria-hidden="true"></span>
          <span class="kel-smtp-state">Работаем…</span>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => overlay.classList.add('is-open'));

    const body    = overlay.querySelector('.kel-smtp-body') as HTMLDivElement;
    const stateEl = overlay.querySelector('.kel-smtp-state') as HTMLSpanElement;
    const footer  = overlay.querySelector('.kel-smtp-footer') as HTMLDivElement;
    const spinner = overlay.querySelector('.kel-smtp-spinner') as HTMLSpanElement;
    const closeBtn = overlay.querySelector('.kel-smtp-close') as HTMLButtonElement;
    const titleEl  = overlay.querySelector('.kel-smtp-title') as HTMLSpanElement;
    let final: DoneEvent | null = null;

    const close = () => {
      overlay.classList.remove('is-open');
      document.body.style.overflow = '';
      setTimeout(() => overlay.remove(), 200);
    };
    closeBtn.addEventListener('click', close);

    function append(level: string, text: string) {
      const line = document.createElement('div');
      line.className = `kel-smtp-line kel-smtp-line--${level}`;
      const marker =
        level === 'ok'     ? '✓ '  :
        level === 'err'    ? '✗ '  :
        level === 'warn'   ? '⚠ '  :
        level === 'wire'   ? '   ' :
        level === 'stage'  ? ''    :
        level === 'prompt' ? '$ '  :
        level === 'sql'    ? '   ' :
        level === 'http'   ? '   ' :
        level === 'header' ? '   ' :
        level === 'send'   ? '→ '  :
        level === 'recv'   ? '← '  :
        level === 'body'   ? '   ' :
                              '› '  ;
      line.textContent = marker + text;
      body.appendChild(line);
      body.scrollTop = body.scrollHeight;
    }

    // Pacing — log lines drain from the queue at this cadence so a fast
    // pipeline (Brevo ~250 ms) still plays out as a watchable terminal
    // session over ~4-5 seconds. Stage headers get extra weight.
    const STEP_MS_DEFAULT = 90;
    const STEP_MS_STAGE   = 280;
    const queue: (LogEvent | DoneEvent)[] = [];
    let drainTimer: number | null = null;
    let streamEnded = false;

    function applyDone(evt: DoneEvent) {
      final = evt;
      spinner.classList.add('is-done');
      spinner.classList.add(evt.ok ? 'is-ok' : 'is-err');
      stateEl.textContent = evt.ok
        ? `Сообщение доставлено (запись №${evt.id ?? '?'})`
        : `Сохранено как №${evt.id ?? '?'}, но отправка письма не удалась: ${evt.error || 'неизвестная ошибка'}`;
      titleEl.textContent = evt.ok ? 'contact-form: готово' : 'contact-form: ошибка';
      closeBtn.hidden = false;
      footer.classList.add(evt.ok ? 'is-ok' : 'is-err');
      setStatus(evt.ok ? 'ok' : 'error', evt.ok
        ? "Спасибо — сообщение получено. Свяжемся в ближайшее время."
        : "Мы сохранили ваше сообщение, но не смогли отправить уведомление по почте. Команда увидит его при следующей проверке.");
      if (evt.ok) form.reset();
      submit?.classList.remove('is-loading');
      submit?.removeAttribute('disabled');
    }

    function drain() {
      const evt = queue.shift();
      if (!evt) {
        if (streamEnded) {
          if (drainTimer != null) clearTimeout(drainTimer);
          drainTimer = null;
        } else {
          drainTimer = window.setTimeout(drain, STEP_MS_DEFAULT);
        }
        return;
      }
      if (evt.type === 'log') {
        append(evt.level || 'info', evt.text || '');
        const next = evt.level === 'stage' ? STEP_MS_STAGE : STEP_MS_DEFAULT;
        drainTimer = window.setTimeout(drain, next);
      } else {
        applyDone(evt);
        drainTimer = null;
      }
    }

    return {
      handle(evt: LogEvent | DoneEvent) {
        queue.push(evt);
        if (drainTimer == null) drain();
      },
      finalizeIfNeeded() {
        streamEnded = true;
        if (!final && !queue.some(e => e.type === 'done')) {
          queue.push({ type: 'log', level: 'warn', text: 'Поток завершён без события done' } as any);
        }
      },
    };
  }

  setupContactForm();
  document.addEventListener('astro:page-load', setupContactForm);
</script>

<style>
  .kel-contact { color: var(--kel-text); }

  .kel-contact__head {
    background: var(--kel-bg-alt);
    border-bottom: 1px solid var(--kel-border);
    padding: 56px 0 36px;
  }
  .kel-contact__head-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 var(--kel-gutter);
  }
  .kel-contact__kicker {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 800;
    color: var(--kel-accent);
    margin-bottom: 8px;
  }
  .kel-contact__title {
    font-family: var(--kel-font-display);
    font-weight: 800;
    font-size: clamp(36px, 6vw, 64px);
    letter-spacing: -0.03em;
    margin: 0 0 12px;
    line-height: 1.05;
  }
  .kel-contact__lede {
    font-size: 17px;
    color: var(--kel-text-2);
    max-width: 70ch;
    margin: 0;
  }
  .kel-contact__lede a {
    color: var(--kel-accent);
    border-bottom: 1px solid rgba(56, 189, 248, .35);
  }

  .kel-contact__body {
    max-width: 1080px;
    margin: 0 auto;
    padding: 56px var(--kel-gutter) 96px;
  }
  .kel-contact__grid {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 880px) {
