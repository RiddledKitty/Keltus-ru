---
/**
 * Lighthouse score comparison panel.
 *
 * Renders two side-by-side cards, each with the four headline Lighthouse
 * scores (Performance / Accessibility / Best Practices / SEO) shown as
 * colored ring gauges — same visual language as Google PageSpeed Insights.
 *
 * Used twice on the home page: SarahSite before/after and NewsTosser vs NYT.
 */

interface Side {
  label:    string;          // e.g. "WordPress (before)"
  caption?: string;          // smaller note under the label
  scores:   [number, number, number, number]; // Performance, A11y, BP, SEO
}

interface Props {
  eyebrow:  string;
  headline: string;
  caption?: string;
  left:     Side;
  right:    Side;
}

const { eyebrow, headline, caption, left, right } = Astro.props;

const metricLabels = ['Производительность', 'Доступность', 'Лучшие практики', 'SEO'] as const;
const metricShort  = ['Перф', 'A11y', 'BP', 'SEO'] as const;

/* Ring color matches Lighthouse's own thresholds: red <50, amber 50-89, green 90+. */
function tone(v: number): 'good' | 'avg' | 'bad' {
  if (v >= 90) return 'good';
  if (v >= 50) return 'avg';
  return 'bad';
}

/* SVG ring geometry. r=22 → circumference ~138. We render a 56px viewport,
 * stroke-width 5, and dash the stroke proportional to score. */
const R = 22;
const CIRC = 2 * Math.PI * R;

function dashOffset(score: number) {
  return CIRC * (1 - Math.max(0, Math.min(100, score)) / 100);
}
---

<section class="kel-ps">
  <header class="kel-ps__head">
    <span class="kel-eyebrow">{eyebrow}</span>
    <h2>{headline}</h2>
    {caption && <p>{caption}</p>}
  </header>

  <div class="kel-ps__cards">
    {[left, right].map((side, sideIdx) => (
      <article class:list={['kel-ps__card', sideIdx === 1 && 'kel-ps__card--right']}>
        <header class="kel-ps__card-head">
          <h3>{side.label}</h3>
          {side.caption && <p>{side.caption}</p>}
        </header>
        <div class="kel-ps__rings" role="list">
          {side.scores.map((s, i) => {
            const t = tone(s);
            return (
              <div class:list={['kel-ps__ring', `is-${t}`]} role="listitem" title={`${metricLabels[i]}: ${s}`}>
                <div class="kel-ps__ring-circle">
                  <svg viewBox="0 0 56 56" aria-hidden="true">
                    <circle class="kel-ps__ring-track" cx="28" cy="28" r={R}></circle>
                    <circle
                      class="kel-ps__ring-arc"
                      cx="28" cy="28" r={R}
                      stroke-dasharray={CIRC}
                      stroke-dashoffset={dashOffset(s)}
                    ></circle>
                  </svg>
                  <span class="kel-ps__ring-val">{s}</span>
                </div>
                <span class="kel-ps__ring-label">{metricShort[i]}</span>
              </div>
            );
          })}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .kel-ps {
    border: 1px solid var(--kel-border);
    border-radius: var(--kel-radius-lg);
    background:
      radial-gradient(120% 80% at 0% 0%, rgba(56,189,248,0.05), transparent 60%),
      var(--kel-bg-alt);
    padding: clamp(28px, 4vw, 48px);
  }
  .kel-ps__head { margin: 0 0 28px; }
  .kel-ps__head h2 {
    font-size: clamp(24px, 3vw, 32px);
    margin: 8px 0 6px;
  }
  .kel-ps__head p {
    margin: 0;
    color: var(--kel-text-2);
    max-width: 64ch;
    font-size: 15px;
  }

  /* Two cards side-by-side */
  .kel-ps__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 720px) {
    .kel-ps__cards { grid-template-columns: 1fr; }
  }

  .kel-ps__card {
    background: var(--kel-bg);
    border: 1px solid var(--kel-border);
    border-radius: var(--kel-radius);
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
  }
  .kel-ps__card--right {
    border-color: var(--kel-accent);
    box-shadow: 0 0 0 1px var(--kel-accent-soft), 0 8px 28px rgba(56, 189, 248, 0.08);
  }
  .kel-ps__card--right::before {
    content: "Наш";
    position: absolute;
    top: -10px;
    right: 14px;
    background: var(--kel-accent);
    color: #04111c;
    font-family: var(--kel-font-mono);
    font-size: 10.5px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .kel-ps__card-head h3 {
    margin: 0 0 4px;
    font-size: 16px;
    font-weight: 700;
    color: var(--kel-text);
  }
  .kel-ps__card-head p {
    margin: 0;
    color: var(--kel-text-3);
    font-family: var(--kel-font-mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
  }

  /* Four ring gauges in a row */
  .kel-ps__rings {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .kel-ps__ring {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .kel-ps__ring-circle {
    position: relative;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }
  .kel-ps__ring-circle svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);    /* arc starts at 12 o'clock */
    display: block;
  }
  .kel-ps__ring-track {
    fill: none;
    stroke: var(--kel-bg-3);
    stroke-width: 5;
  }
  .kel-ps__ring-arc {
    fill: none;
    stroke-width: 5;
    stroke-linecap: round;
    transition: stroke-dashoffset .8s ease;
  }
  .kel-ps__ring.is-good .kel-ps__ring-arc { stroke: var(--kel-success); }
  .kel-ps__ring.is-avg  .kel-ps__ring-arc { stroke: var(--kel-warn); }
  .kel-ps__ring.is-bad  .kel-ps__ring-arc { stroke: var(--kel-danger); }

  .kel-ps__ring-val {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--kel-font-mono);
    font-weight: 700;
    font-size: 18px;
    color: var(--kel-text);
    line-height: 1;
  }
  .kel-ps__ring.is-good .kel-ps__ring-val { color: var(--kel-success); }
  .kel-ps__ring.is-avg  .kel-ps__ring-val { color: var(--kel-warn); }
  .kel-ps__ring.is-bad  .kel-ps__ring-val { color: var(--kel-danger); }

  .kel-ps__ring-label {
    font-family: var(--kel-font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--kel-text-3);
    text-align: center;
  }

  /* When cards get narrow, wrap rings 2x2 instead of letting them shrink */
  @media (max-width: 880px) and (min-width: 721px) {
    .kel-ps__rings { grid-template-columns: repeat(2, 1fr); }
  }
</style>
