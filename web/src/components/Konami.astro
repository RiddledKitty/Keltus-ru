---
/* Konami code easter egg. Press ↑ ↑ ↓ ↓ ← → ← → B A and the page
 * briefly drops into a digital-rain mode with the wolf crest
 * framed in the center.
 *
 * The image is editable in Directus → site_config → konami_image.
 * Falls back to /img/badvolf.png (public asset) when unset.
 *
 * Class names kept as kel-konami-* for legacy CSS selector matches. */
interface Props { image?: string; }
const { image = '/img/badvolf.png' } = Astro.props;
---
<style is:global>
  .kel-konami-canvas {
    /* Canvas defaults to display:inline; without block + explicit
     * width/height, inset:0 doesn't size it and the rain only paints
     * into the top-left 300×150 corner. */
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 2147483646;
    opacity: 0;
    transition: opacity .35s ease;
  }
  .kel-konami-canvas.is-on { opacity: 1; }

  .kel-konami-frame {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(.85);
    z-index: 2147483647;
    width: min(60vmin, 420px);
    aspect-ratio: 1 / 1;
    padding: 14px;
    background: #060606;
    border-radius: 50%;
    box-shadow:
      0 0 0 2px #f7d40e,
      0 0 0 6px rgba(0, 0, 0, .85),
      0 0 0 8px #f7d40e,
      0 0 60px rgba(247, 212, 14, .55),
      0 0 120px rgba(247, 212, 14, .3);
    opacity: 0;
    transition: opacity .35s ease, transform .35s cubic-bezier(.2, .9, .3, 1.25);
    pointer-events: none;
  }
  .kel-konami-frame.is-on {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
  .kel-konami-frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
    display: block;
  }
</style>

<script define:vars={{ WOLF_IMAGE: image }}>
  const SEQUENCE = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
  const KONAMI_DURATION_MS = 5500;
  let pos = 0;
  let running = false;

  document.addEventListener('keydown', (e) => {
    const k = e.key.length === 1 ? e.key.toLowerCase() : e.key;
    if (k === SEQUENCE[pos]) {
      pos++;
      if (pos === SEQUENCE.length) {
        pos = 0;
        if (!running) trigger();
      }
    } else {
      pos = k === SEQUENCE[0] ? 1 : 0;
    }
  });

  function trigger() {
    running = true;

    const canvas = document.createElement('canvas');
    canvas.className = 'kel-konami-canvas';
    document.body.appendChild(canvas);

    const frame = document.createElement('div');
    frame.className = 'kel-konami-frame';
    const img = document.createElement('img');
    img.src = WOLF_IMAGE;
    img.alt = '';
    img.decoding = 'async';
    frame.appendChild(img);
    document.body.appendChild(frame);

    requestAnimationFrame(() => {
      canvas.classList.add('is-on');
      frame.classList.add('is-on');
    });

    const ctx = canvas.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const resize = () => {
      const r = canvas.getBoundingClientRect();
      canvas.width = r.width * dpr;
      canvas.height = r.height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener('resize', resize);

    const FONT_SIZE = 16;
    const COL_W = FONT_SIZE * 1.1;
    const columns = [];
    const initCols = () => {
      columns.length = 0;
      const r = canvas.getBoundingClientRect();
      const n = Math.ceil(r.width / COL_W);
      for (let i = 0; i < n; i++) {
        columns.push({ y: -Math.random() * r.height, speed: 2 + Math.random() * 4 });
      }
    };
    initCols();

    ctx.font = `${FONT_SIZE}px ui-monospace, SFMono-Regular, Menlo, Monaco, monospace`;
    ctx.textBaseline = 'top';

    let raf = 0;
    const start = performance.now();

    function step(now) {
      const r = canvas.getBoundingClientRect();
      const fade = now - start > KONAMI_DURATION_MS - 600
        ? Math.max(0, 1 - (now - start - (KONAMI_DURATION_MS - 600)) / 600)
        : 1;

      const elapsed = now - start;
      const bgAlpha = elapsed < 200 ? 0.7 : 0.16;
      ctx.fillStyle = `rgba(6, 6, 6, ${bgAlpha})`;
      ctx.fillRect(0, 0, r.width, r.height);

      for (let i = 0; i < columns.length; i++) {
        const c = columns[i];
        const ch = Math.random() < 0.5 ? '0' : '1';
        const x = i * COL_W + 2;
        // Head — gold
        ctx.fillStyle = `rgba(247, 212, 14, ${fade})`;
        ctx.fillText(ch, x, c.y);
        // Trail tail — dim red wisps (matches BadVolf crest)
        if (Math.random() < 0.4) {
          ctx.fillStyle = `rgba(220, 38, 38, ${0.32 * fade})`;
          ctx.fillText(Math.random() < 0.5 ? '0' : '1', x, c.y - FONT_SIZE * 1.5);
        }
        c.y += c.speed;
        if (c.y > r.height) {
          c.y = -Math.random() * 80;
          c.speed = 2 + Math.random() * 4;
        }
      }

      if (now - start < KONAMI_DURATION_MS) {
        raf = requestAnimationFrame(step);
      } else {
        canvas.classList.remove('is-on');
        frame.classList.remove('is-on');
        setTimeout(() => {
          window.removeEventListener('resize', resize);
          canvas.remove();
          frame.remove();
          running = false;
        }, 400);
      }
    }
    raf = requestAnimationFrame(step);
  }
</script>
