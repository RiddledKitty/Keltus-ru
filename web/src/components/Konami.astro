---
// Konami code easter egg. Press ↑ ↑ ↓ ↓ ← → ← → B A and the synaptic
// network briefly morphs into a binary-rain mode with a tiny toast. Gentle
// nod to the cliché we deliberately rejected for the hero.
//
// The toast text is editable from Directus → site_config → konami_toast.
interface Props { toast?: string; }
const { toast = 'да, мы знаем — но синапсы всё равно лучше.' } = Astro.props;
---
<style is:global>
  .kel-konami-canvas {
    /* `<canvas>` is display:inline by default — without `display:block` plus
     * explicit width/height, `inset:0` doesn't size it and it stays at the
     * intrinsic 300×150, so the rain only renders into the top-left. */
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    /* Above everything: nav (50), terminal/lightbox overlays (1000),
     * contact form terminal (1000). Toast sits one above the canvas. */
    z-index: 2147483646;
    opacity: 0;
    transition: opacity .35s ease;
  }
  .kel-konami-canvas.is-on { opacity: 1; }

  /* Single-line toast — pill at top of screen, with a leading dot. */
  .kel-konami-toast {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translate(-50%, -8px);
    z-index: 2147483647;
    padding: 10px 18px;
    background: #060c14;
    border: 1px solid var(--kel-fiber);
    border-radius: 999px;
    font-family: var(--kel-font-mono);
    font-size: 13px;
    color: var(--kel-text);
    box-shadow: 0 8px 32px rgba(232, 121, 249, .25);
    opacity: 0;
    transition: opacity .2s ease, transform .2s ease;
    pointer-events: none;
    white-space: nowrap;
    max-width: calc(100vw - 32px);
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .kel-konami-toast.is-on {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  .kel-konami-toast::before {
    content: '◉';
    color: #67e8f9;
    margin-right: 8px;
  }

  /* Multi-line ASCII-art mode — centered on screen, monospace pre, no dot.
     Font size scales so the largest line fits within the viewport. */
  .kel-konami-toast.is-ascii {
    top: 50%;
    left: 50%;
    transform: translate(-50%, calc(-50% + 8px));
    padding: 18px 22px;
    border-radius: 14px;
    background: rgba(6, 12, 20, 0.78);
    backdrop-filter: blur(2px);
    white-space: pre;
    overflow: visible;
    text-overflow: clip;
    max-width: 96vw;
    max-height: 92vh;
    line-height: 1;
    text-align: center;
    font-size: clamp(5px, 1.2vmin, 12px);
  }
  .kel-konami-toast.is-ascii.is-on {
    transform: translate(-50%, -50%);
  }
  .kel-konami-toast.is-ascii::before { content: none; }
</style>

<script define:vars={{ TOAST_TEXT: toast }}>
  const SEQUENCE = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
  const KONAMI_DURATION_MS = 5000;
  let pos = 0;
  let running = false;

  document.addEventListener('keydown', (e) => {
    const k = e.key.length === 1 ? e.key.toLowerCase() : e.key;
    if (k === SEQUENCE[pos]) {
      pos++;
      if (pos === SEQUENCE.length) {
        pos = 0;
        if (!running) trigger();
      }
    } else {
      pos = k === SEQUENCE[0] ? 1 : 0;
    }
  });

  function trigger() {
    running = true;

    const canvas = document.createElement('canvas');
    canvas.className = 'kel-konami-canvas';
    document.body.appendChild(canvas);

    const toast = document.createElement('div');
    toast.className = 'kel-konami-toast';
    // Multi-line copy gets monospace ASCII-art treatment; single-line stays as the pill.
    if (TOAST_TEXT.includes('\n')) toast.classList.add('is-ascii');
    toast.textContent = TOAST_TEXT;
    document.body.appendChild(toast);

    requestAnimationFrame(() => {
      canvas.classList.add('is-on');
      toast.classList.add('is-on');
    });

    const ctx = canvas.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const resize = () => {
      const r = canvas.getBoundingClientRect();
      canvas.width = r.width * dpr;
      canvas.height = r.height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener('resize', resize);

    const FONT_SIZE = 16;
    const COL_W = FONT_SIZE * 1.1;
    const columns = [];
    const initCols = () => {
      columns.length = 0;
      const r = canvas.getBoundingClientRect();
      const n = Math.ceil(r.width / COL_W);
      for (let i = 0; i < n; i++) {
        columns.push({ y: -Math.random() * r.height, speed: 2 + Math.random() * 4 });
      }
    };
    initCols();

    ctx.font = `${FONT_SIZE}px var(--kel-font-mono), monospace`;
    ctx.textBaseline = 'top';

    let raf = 0;
    const start = performance.now();

    function frame(now) {
      const r = canvas.getBoundingClientRect();
      const fade = now - start > KONAMI_DURATION_MS - 600
        ? Math.max(0, 1 - (now - start - (KONAMI_DURATION_MS - 600)) / 600)
        : 1;

      // Build up the dark overlay quickly on the first frame so the page
      // content behind disappears into the matrix; subsequent frames use
      // a lighter fade to keep the falling-trail effect.
      const elapsed = now - start;
      const bgAlpha = elapsed < 200 ? 0.65 : 0.18;
      ctx.fillStyle = `rgba(4, 8, 14, ${bgAlpha})`;
      ctx.fillRect(0, 0, r.width, r.height);

      for (let i = 0; i < columns.length; i++) {
        const c = columns[i];
        const ch = Math.random() < 0.5 ? '0' : '1';
        const x = i * COL_W + 2;
        // Head — bright cyan
        ctx.fillStyle = `rgba(103, 232, 249, ${fade})`;
        ctx.fillText(ch, x, c.y);
        // Trail tail — magenta wisps a few rows up
        if (Math.random() < 0.4) {
          ctx.fillStyle = `rgba(232, 121, 249, ${0.35 * fade})`;
          ctx.fillText(Math.random() < 0.5 ? '0' : '1', x, c.y - FONT_SIZE * 1.5);
        }
        c.y += c.speed;
        if (c.y > r.height) {
          c.y = -Math.random() * 80;
          c.speed = 2 + Math.random() * 4;
        }
      }

      if (now - start < KONAMI_DURATION_MS) {
        raf = requestAnimationFrame(frame);
      } else {
        canvas.classList.remove('is-on');
        toast.classList.remove('is-on');
        setTimeout(() => {
          window.removeEventListener('resize', resize);
          canvas.remove();
          toast.remove();
          running = false;
        }, 400);
      }
    }
    raf = requestAnimationFrame(frame);
  }
</script>
