# Analytics Go service — keltus.ru

# Bind address
KELTUS_ANALYTICS_LISTEN="127.0.0.1:4330"

# MariaDB DSN. The Go service reuses the same MariaDB instance as
# Directus but writes to its own database (analytics_*).
KELTUS_ANALYTICS_DSN="keltus_analytics:CHANGEME@tcp(127.0.0.1:3306)/keltus_analytics"

# Canonical site host — used to collapse self-referrals to "(direct)".
KELTUS_ANALYTICS_OWN_HOST="keltus.ru"

# Path to GeoLite2-City.mmdb (optional).
KELTUS_ANALYTICS_GEOIP="/var/lib/GeoIP/GeoLite2-City.mmdb"

# Required for /admin/* endpoints (the Directus analytics module sends it).
# Leave empty in dev; nginx + Directus session is enough.
KELTUS_ANALYTICS_ADMIN_TOKEN=""
