[Unit]
Description=Keltus CMS (Directus)
After=network.target mariadb.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/keltus.ru/cms
EnvironmentFile=/var/www/keltus.ru/cms/.env
ExecStart=/usr/bin/node node_modules/.bin/directus start
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
