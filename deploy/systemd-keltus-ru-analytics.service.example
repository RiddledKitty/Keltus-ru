[Unit]
Description=Keltus analytics service
After=network.target mariadb.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/keltus.ru/analytics
EnvironmentFile=/var/www/keltus.ru/analytics/.env
ExecStart=/var/www/keltus.ru/analytics/keltusanalytics
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
